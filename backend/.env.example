# MongoDB : base locale OU MongoDB Atlas (gratuit, sans installer MongoDB sur la machine)
# Exemple Atlas : mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/techstore?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/techstore

PORT=3000

JWT_SECRET=remplace_par_une_chaine_longue_et_aleatoire
JWT_EXPIRES_IN=7d

# Optionnel : premier compte admin créé par npm run seed
SEED_ADMIN_EMAIL=admin@techstore.local
SEED_ADMIN_PASSWORD=admin123
SEED_VENDEUR_EMAIL=vendeur@techstore.local
SEED_VENDEUR_PASSWORD=vendeur123
